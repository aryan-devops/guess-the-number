rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY:
     * This ruleset implements a robust multiplayer gaming security model. It prioritizes 
     * Authorization Independence by denormalizing key IDs (like player1Id, player2Id) 
     * onto child documents to avoid costly get() calls.
     * 
     * DATA STRUCTURE:
     * - /userProfiles/{userId}: Publicly viewable profiles, privately managed by the owner.
     * - /gameRooms/{gameRoomId}: Collaborative spaces for game setup and discovery.
     * - /gameRooms/{gameRoomId}/gameMatches/...: Private match instances restricted to participants.
     * - /leaderboard/{userId}: Public read-only ranking system managed by backend processes.
     * 
     * KEY SECURITY DECISIONS:
     * 1. Public Read/Private Write: User profiles and the leaderboard are readable by all to 
     *    facilitate social features and discovery.
     * 2. Shared Access: Game rooms and matches use membership-based authorization (playerIds).
     * 3. Denormalization: Authorization fields are copied to sub-documents (Guesses, ChatMessages) 
     *    to ensure rules are fast and atomic.
     * 4. Backend Only: The leaderboard is strictly read-only for clients to ensure integrity.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isPlayerInRoom(roomData) {
      return isSignedIn() && (request.auth.uid in roomData.playerIds || request.auth.uid == roomData.hostId);
    }

    function isPlayerInMatch(matchData) {
      return isSignedIn() && (request.auth.uid == matchData.player1Id || request.auth.uid == matchData.player2Id);
    }

    // FIX: The 'isCurrentTurn' function was unused. It has been integrated into the
    //      '/gameRooms/{gameRoomId}/gameMatches/{gameMatchId}' update rule
    //      to enforce turn-based control over modifying the 'currentTurnPlayerId'.
    function isCurrentTurn(matchData) {
      return isSignedIn() && request.auth.uid == matchData.currentTurnPlayerId;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for UserProfile. Allows public viewing of player stats but limits edits to the owner.
     * @path /userProfiles/{userId}
     * @allow (get) Any user requesting a specific profile.
     * @allow (create) Authenticated user where request.auth.uid matches the document ID.
     * @deny (update) Any user trying to modify a profile they do not own.
     * @principle Path-based ownership for writes; Public read for social display.
     */
    match /userProfiles/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for GameRoom. Facilitates discovery of open rooms and restricts access to joined players.
     * @path /gameRooms/{gameRoomId}
     * @allow (list) All users can list rooms with status 'waitingForPlayers'.
     * @allow (update) Any player or host currently associated with the room.
     * @deny (create) User attempting to set a different hostId than their own UID.
     * @principle Shared access via membership list (playerIds/hostId).
     */
    match /gameRooms/{gameRoomId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (resource.data.status == 'waitingForPlayers' || isPlayerInRoom(resource.data));
      allow create: if isSignedIn() && request.resource.data.hostId == request.auth.uid;
      allow update: if resource != null && isPlayerInRoom(resource.data);
      allow delete: if resource != null && resource.data.hostId == request.auth.uid;

      /**
       * @description Rules for GameMatch. Private sub-collection for the active duel.
       * @path /gameRooms/{gameRoomId}/gameMatches/{gameMatchId}
       * @allow (get) Only players identified in the match data (player1Id/player2Id).
       * @allow (update) Participants of the match to update game state (turn, scores).
       * @deny (create) User not listed as one of the players in the match data.
       * @principle Denormalization for authorization independence.
       */
      match /gameMatches/{gameMatchId} {
        allow get, list: if isPlayerInMatch(resource.data);
        allow create: if isSignedIn() && (request.auth.uid == request.resource.data.player1Id || request.auth.uid == request.resource.data.player2Id);
        // FIX: Applied 'isCurrentTurn' to the update rule for GameMatch documents.
        //      Allows any player to update if the 'currentTurnPlayerId' isn't changing,
        //      but only the current player can change 'currentTurnPlayerId'.
        allow update: if resource != null && isPlayerInMatch(resource.data) && (request.resource.data.currentTurnPlayerId == resource.data.currentTurnPlayerId || isCurrentTurn(resource.data));
        allow delete: if resource != null && isPlayerInMatch(resource.data);

        /**
         * @description Rules for Guess. Ensures only the active player can submit a guess.
         * @path /gameRooms/{gameRoomId}/gameMatches/{gameMatchId}/guesses/{guessId}
         * @allow (create) The player whose turn it is, matching their playerId.
         * @deny (update/delete) Guesses are immutable once submitted.
         * @principle Relational integrity and turn-based write restriction.
         */
        match /guesses/{guessId} {
          allow get, list: if isPlayerInMatch(resource.data);
          allow create: if isSignedIn() && request.resource.data.playerId == request.auth.uid && (request.auth.uid == request.resource.data.player1Id || request.auth.uid == request.resource.data.player2Id);
          allow update, delete: if false;
        }
      }

      /**
       * @description Rules for ChatMessage. Secure messaging within a game room.
       * @path /gameRooms/{gameRoomId}/chatMessages/{chatMessageId}
       * @allow (create) Any player in the room can send a message.
       * @deny (list) Users not part of the game room.
       * @principle Shared access restricted to room collaborators.
       */
      match /chatMessages/{chatMessageId} {
        allow get, list: if isPlayerInRoom(resource.data);
        allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid && isPlayerInRoom(request.resource.data);
        allow update, delete: if false;
      }
    }

    /**
     * @description Rules for LeaderboardEntry. Public global ranking data.
     * @path /leaderboard/{userId}
     * @allow (get, list) Any authenticated user to view the rankings.
     * @deny (write) Any client-side write operation. Data is backend-managed.
     * @principle Read-only public collection for data integrity.
     */
    match /leaderboard/{userId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }
  }
}