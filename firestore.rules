rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY:
     * This ruleset implements a robust multiplayer gaming security model. It prioritizes 
     * Authorization Independence by denormalizing key IDs onto child documents.
     * 
     * DATA STRUCTURE:
     * - /userProfiles/{userId}: Publicly viewable profiles, privately managed by the owner.
     * - /gameRooms/{gameRoomId}: Collaborative spaces for game setup and discovery.
     * - /gameRooms/{gameRoomId}/gameMatches/...: Private match instances restricted to participants.
     * - /leaderboard/{userId}: Public read-only ranking system managed by backend processes.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isPlayerInRoom(roomData) {
      return isSignedIn() && (roomData == null || request.auth.uid in roomData.playerIds || request.auth.uid == roomData.hostId);
    }

    function isPlayerInMatch(matchData) {
      return isSignedIn() && (matchData == null || request.auth.uid in matchData.playerIds);
    }

    function isCurrentTurn(matchData) {
      return isSignedIn() && matchData != null && request.auth.uid == matchData.currentTurnPlayerId;
    }

    // --- Collection Rules ---

    match /userProfiles/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == userId;
      allow delete: if isExistingOwner(userId);
    }

    match /gameRooms/{gameRoomId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (resource == null || resource.data.status == 'waitingForPlayers' || isPlayerInRoom(resource.data));
      allow create: if isSignedIn() && request.resource.data.hostId == request.auth.uid;
      allow update: if resource != null && isPlayerInRoom(resource.data);
      allow delete: if resource != null && resource.data.hostId == request.auth.uid;

      match /gameMatches/{gameMatchId} {
        // Explicit check for null resource to allow initialized listeners to wait for doc creation
        allow get, list: if isSignedIn() && (resource == null || request.auth.uid in resource.data.playerIds);
        allow create: if isSignedIn() && (request.auth.uid in request.resource.data.playerIds);
        allow update: if resource != null && isPlayerInMatch(resource.data) && (request.resource.data.currentTurnPlayerId == resource.data.currentTurnPlayerId || isCurrentTurn(resource.data));
        allow delete: if resource != null && isPlayerInMatch(resource.data);

        match /guesses/{guessId} {
          // Alignment with query filters using denormalized playerIds
          allow get, list: if isSignedIn() && (resource == null || request.auth.uid in resource.data.playerIds);
          allow create: if isSignedIn() && request.resource.data.playerId == request.auth.uid && (request.auth.uid in request.resource.data.playerIds);
          allow update, delete: if false;
        }
      }

      match /chatMessages/{chatMessageId} {
        allow get, list: if isSignedIn() && (resource == null || isPlayerInRoom(resource.data));
        allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid && isPlayerInRoom(request.resource.data);
        allow update, delete: if false;
      }
    }

    match /leaderboard/{userId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }
  }
}