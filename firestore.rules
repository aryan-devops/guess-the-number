rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY:
     * Robust multiplayer security. Participants in a room have access to the match and guess history.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    match /userProfiles/{userId} {
      allow get, list: if isSignedIn();
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /gameRooms/{gameRoomId} {
      // Anyone signed in can find or join a room
      allow get, list, create: if isSignedIn();
      allow update: if isSignedIn(); 
      allow delete: if isSignedIn() && resource.data.hostId == request.auth.uid;

      match /gameMatches/{gameMatchId} {
        // Participants in the parent room can access matches
        allow get, list, create, update, delete: if isSignedIn();

        match /guesses/{guessId} {
          // Participants can see all guesses in the match for the history panel
          allow get, list: if isSignedIn();
          allow create: if isSignedIn() && request.resource.data.playerId == request.auth.uid;
          allow update, delete: if false;
        }
      }

      match /chatMessages/{chatMessageId} {
        allow get, list, create: if isSignedIn();
        allow update, delete: if false;
      }
    }

    match /leaderboard/{userId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }
  }
}