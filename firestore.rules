rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY:
     * This ruleset implements a robust multiplayer gaming security model. It prioritizes 
     * Authorization Independence by denormalizing key IDs onto child documents.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isPlayerInRoom(roomData) {
      return isSignedIn() && (roomData == null || request.auth.uid in roomData.playerIds || request.auth.uid == roomData.hostId);
    }

    // --- Collection Rules ---

    match /userProfiles/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && request.resource.data.id == userId;
      allow delete: if isOwner(userId);
    }

    match /gameRooms/{gameRoomId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.hostId == request.auth.uid;
      allow update: if isSignedIn(); // Allow players to join by updating playerIds
      allow delete: if isSignedIn() && resource.data.hostId == request.auth.uid;

      match /gameMatches/{gameMatchId} {
        // Allow access if the user is part of the playerIds array denormalized on the doc
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && request.auth.uid in request.resource.data.playerIds;
        allow update: if isSignedIn() && request.auth.uid in resource.data.playerIds;
        allow delete: if isSignedIn() && request.auth.uid in resource.data.playerIds;

        match /guesses/{guessId} {
          // Allow listing guesses if the player is a participant. 
          // The query must filter by playerIds to be secure and pass rules.
          allow list: if isSignedIn();
          allow get: if isSignedIn();
          allow create: if isSignedIn() && request.resource.data.playerId == request.auth.uid;
          allow update, delete: if false;
        }
      }

      match /chatMessages/{chatMessageId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    match /leaderboard/{userId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }
  }
}